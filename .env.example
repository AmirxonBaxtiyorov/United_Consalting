# --- Site ---
NEXT_PUBLIC_SITE_URL=https://global-consalting.vercel.app

# --- Supabase ---
# Create tables per schema in /docs/supabase-schema.sql (leads, blog_posts, etc.)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...public anon key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...server-side service role key...

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM="United Global Consulting <noreply@unitedglobal.uz>"
MANAGER_EMAIL=manager@unitedglobal.uz

# --- Telegram bot (lead notifications) ---
# 1. @BotFather -> /newbot, get TOKEN
# 2. Add the bot to your managers' group, send a message, then:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates  -> chat.id
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=
